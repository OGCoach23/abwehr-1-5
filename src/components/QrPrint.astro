---
// QR-Code zeigt auf die feste Live-URL. Bei eigener Domain FIXED_URL unten setzen.
---

<div class="qr" id="print-area">
  <h3 class="qr__title">Häng die 1:5 in der Kabine aus</h3>
  <p class="qr__sub">Scann den Code oder druck ihn als Aushang fürs Team.</p>
  <div class="qr__code" id="qrcode" role="img" aria-label="QR-Code zu dieser Seite"></div>
  <div class="qr__url" id="qr-url">Lädt …</div>
  <button class="cta cta--ghost qr__print" type="button" data-print>🖨 QR-Code drucken</button>
</div>

<style>
  .qr {
    text-align: center;
    background: var(--bg-cream);
    color: var(--green-darkest);
    border-radius: var(--radius-card);
    padding: clamp(1.6rem, 4vw, 2.4rem);
    max-width: 380px;
    margin-inline: auto;
    box-shadow: var(--shadow-lg);
  }
  .qr__title {
    font-size: 1.3rem;
  }
  .qr__sub {
    margin: 0.5rem 0 1.3rem;
    color: var(--cream-dim);
    font-size: 0.95rem;
  }
  .qr__code {
    display: inline-block;
    background: #fff;
    padding: 12px;
    border-radius: 8px;
    line-height: 0;
  }
  .qr__code :global(img) {
    width: 180px;
    height: 180px;
    image-rendering: pixelated;
  }
  .qr__url {
    margin: 1rem 0 1.3rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    word-break: break-all;
    color: var(--green-primary);
  }
  .qr__print {
    color: var(--green-dark);
  }

  @media print {
    body * {
      visibility: hidden !important;
    }
    #print-area,
    #print-area * {
      visibility: visible !important;
    }
    #print-area {
      position: absolute;
      inset: 0;
      margin: auto;
      box-shadow: none;
    }
    .qr__print {
      display: none !important;
    }
  }
</style>

<script>
  import qrcode from "../lib/qrcode.js";

  const FIXED_URL = "https://abwehr-1-5.vercel.app"; // bei eigener Domain hier anpassen
  const url = FIXED_URL || window.location.origin + window.location.pathname;

  try {
    const qr = qrcode(0, "M");
    qr.addData(url);
    qr.make();
    const holder = document.getElementById("qrcode");
    if (holder) holder.innerHTML = qr.createImgTag(6, 8);
    const urlEl = document.getElementById("qr-url");
    if (urlEl) urlEl.textContent = url.replace(/^https?:\/\//, "");
  } catch (e) {
    const urlEl = document.getElementById("qr-url");
    if (urlEl) urlEl.textContent = url;
  }

  document.querySelector("[data-print]")?.addEventListener("click", () => window.print());
</script>
