---
interface Props {
  num: number;
  title: string;
  tip?: string;
  /** Basis-Dateiname ohne Endung in /videos, z. B. "step1". Optional. */
  video?: string;
  caption?: string;
  /** "portrait" (Hochformat) oder "landscape" */
  orient?: "portrait" | "landscape";
}
const { num, title, tip, video, caption, orient = "portrait" } = Astro.props;
---

<article class="step reveal">
  <div class="step__num" aria-hidden="true">{String(num).padStart(2, "0")}</div>
  <div class="step__body">
    <h3 class="step__title">{title}</h3>
    <p class="step__text"><slot /></p>
    {tip && <p class="step__tip">{tip}</p>}
  </div>

  {
    video && (
      <figure class={`step__figure step__figure--${orient}`}>
        <div class="vbox" data-video>
          <video preload="none" playsinline controls poster={`/videos/${video}.jpg`}>
            <source src={`/videos/${video}.mp4`} type="video/mp4" />
          </video>
          <button class="vbox__play" type="button" aria-label={`Video abspielen: ${caption ?? title}`}>
            <span class="vbox__tri" aria-hidden="true" />
          </button>
        </div>
        {caption && <figcaption class="step__cap">{caption}</figcaption>}
      </figure>
    )
  }
</article>

<style>
  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 1px solid rgba(168, 213, 188, 0.22);
  }
  .step__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-mega);
    line-height: 0.8;
    color: var(--green-mid);
    opacity: 0.9;
  }
  .step__title {
    font-size: var(--fs-h3);
    margin-bottom: 0.6rem;
  }
  .step__text {
    color: var(--green-mint);
    max-width: 52ch;
  }
  .step__tip {
    display: inline-block;
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--warn);
    border: 1px solid rgba(255, 212, 0, 0.4);
    padding: 0.4em 0.8em;
    border-radius: var(--radius-badge);
  }

  .step__figure {
    grid-column: 2;
    margin: 1.4rem 0 0;
  }
  .step__figure--portrait .vbox {
    max-width: 360px;
    aspect-ratio: 3 / 4;
  }
  .step__figure--landscape .vbox {
    max-width: 560px;
    aspect-ratio: 16 / 9;
  }

  .vbox {
    position: relative;
    width: 100%;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: #000;
    box-shadow: var(--shadow-lg);
  }
  .vbox video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .vbox__play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    border: 0;
    background: rgba(10, 20, 16, 0.32);
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .vbox__play:hover {
    background: rgba(10, 20, 16, 0.12);
  }
  .vbox__play.is-hidden {
    display: none;
  }
  .vbox__tri {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--green-primary);
    display: grid;
    place-items: center;
    box-shadow: var(--shadow);
  }
  .vbox__tri::before {
    content: "";
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 13px 0 13px 21px;
    border-color: transparent transparent transparent var(--bg-cream);
    margin-left: 5px;
  }
  .step__cap {
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--mint-dim);
  }

  @media (max-width: 560px) {
    .step {
      grid-template-columns: 1fr;
    }
    .step__num {
      grid-row: 1;
    }
    .step__figure {
      grid-column: 1;
    }
  }
</style>

<script>
  document.querySelectorAll("[data-video]").forEach((box) => {
    const video = box.querySelector("video");
    const btn = box.querySelector(".vbox__play");
    if (!(video instanceof HTMLVideoElement) || !btn) return;
    btn.addEventListener("click", () => {
      btn.classList.add("is-hidden");
      video.play().catch(() => {});
    });
    video.addEventListener("pause", () => btn.classList.remove("is-hidden"));
    video.addEventListener("play", () => btn.classList.add("is-hidden"));
  });
</script>
